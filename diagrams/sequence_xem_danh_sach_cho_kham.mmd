sequenceDiagram
    actor BS as Bác sĩ
    participant FE as Frontend (TodaySchedulePage)
    participant BE as Backend (SpringBoot)
    participant DB as Database
    participant WS as WebSocketBroker

    %% ═══════════════════════════════════
    %% 1. TẢI TRANG & DỮ LIỆU BAN ĐẦU
    %% ═══════════════════════════════════
    Note over BS, FE: 1. Truy cập trang "Danh sách bệnh nhân"
    BS->>FE: Truy cập trang /doctor/today
    activate FE
    
    FE->>BE: GET /api/doctors (lấy danh sách bác sĩ)
    activate BE
    BE->>DB: Truy vấn thông tin bác sĩ
    DB-->>BE: Trả về danh sách
    BE-->>FE: Trả về danh sách bác sĩ
    deactivate BE

    Note over FE: Khớp user.id hiện tại để lấy doctorId

    par Tải danh sách chờ khám
        FE->>BE: GET /api/appointments/queue?doctorId={id}&date={today}
        activate BE
        BE->>DB: findByDoctorIdAndDate (status = checked_in hoặc in_progress)
        DB-->>BE: Danh sách hàng chờ
        BE-->>FE: Trả về danh sách hàng chờ (queue)
        deactivate BE
    and Tải lịch khám tổng quan trong ngày
        FE->>BE: GET /api/appointments/schedule?doctorId={id}&date={today}
        activate BE
        BE->>DB: findByDoctorIdAndDate (status: confirmed/checked_in/in_progress/done)
        DB-->>BE: Danh sách lịch hẹn trong ngày
        BE-->>FE: Trả về danh sách lịch trong ngày (schedule)
        deactivate BE
    end

    Note over FE: Gộp dữ liệu & phân loại theo trạng thái:<br/>1. Chờ khám (checked_in - sắp xếp theo queueNumber)<br/>2. Đang khám (in_progress)<br/>3. Đã khám (done - sắp xếp theo queueNumber)

    FE-->>BS: Hiển thị danh sách bệnh nhân và các tab trạng thái
    deactivate FE

    %% ═══════════════════════════════════
    %% 2. LẮNG NGHE & CẬP NHẬT REAL-TIME QUA WEBSOCKET
    %% ═══════════════════════════════════
    Note over FE, WS: Đăng ký lắng nghe WebSocket khi có thay đổi
    FE->>WS: Subscribe topic: /topic/doctor/{doctorId}
    
    opt Lễ tân check-in hoặc có thay đổi hàng chờ từ hệ thống
        WS-->>FE: Gửi event "queue_updated"
        activate FE
        Note over FE: Tự động tải lại dữ liệu (load)
        par Tải danh sách chờ khám
            FE->>BE: GET /api/appointments/queue
            BE-->>FE: Trả về danh sách
        and Tải lịch khám tổng quan
            FE->>BE: GET /api/appointments/schedule
            BE-->>FE: Trả về danh sách
        end
        FE-->>BS: Cập nhật giao diện danh sách thực tế
        deactivate FE
    end

    %% ═══════════════════════════════════
    %% 3. TÌM KIẾM/LỌC BỆNH NHÂN (CLIENT-SIDE)
    %% ═══════════════════════════════════
    opt Bác sĩ tìm kiếm bệnh nhân
        BS->>FE: Nhập tên hoặc mã bệnh nhân vào ô tìm kiếm
        activate FE
        Note over FE: Lọc danh sách trực tiếp trên Client<br/>(Không gọi API)
        FE-->>BS: Hiển thị kết quả tìm kiếm đã lọc
        deactivate FE
    end

    %% ═══════════════════════════════════
    %% 4. TIẾP NHẬN BỆNH NHÂN VÀO KHÁM
    %% ═══════════════════════════════════
    Note over BS, FE: Bác sĩ nhấn nút "Gọi khám" (Khám)
    BS->>FE: Click "Gọi khám" (bệnh nhân trạng thái checked_in)
    activate FE
    Note over FE: Đặt trạng thái calling = appointmentId (hiện spinner, disable nút)

    FE->>BE: PUT /api/appointments/{id}/status (body: { status: "in_progress" })
    activate BE

    BE->>DB: Kiểm tra trạng thái hiện tại (phải là checked_in)
    BE->>DB: Cập nhật status = in_progress
    
    %% Phát các thông báo
    par Gửi thông tin real-time cho các bên liên quan
        BE->>WS: Gửi "appointment_updated" tới Receptionist
        BE->>WS: Gửi "appointment_updated" tới Patient (nếu có tài khoản)
        BE->>WS: Gửi "queue_updated" tới Doctor
    and Tạo thông báo DB (notification bell) cho bệnh nhân
        BE->>DB: Lưu thông báo: "Đến lượt của bạn! Bác sĩ đang gọi vào khám."
    end
    
    BE-->>FE: Trả về thông tin lịch hẹn đã cập nhật
    deactivate BE

    alt Cập nhật thành công
        FE->>FE: Điều hướng sang trang khám chi tiết: `/doctor/examine/{id}`
        FE-->>BS: Hiển thị màn hình Thực hiện khám bệnh
    else Có lỗi xảy ra (ví dụ: mất kết nối, lịch đã đổi trạng thái)
        FE-->>FE: Hiển thị thông báo lỗi lên màn hình & Reset calling state
        FE->>FE: Tự động tải lại danh sách (load) để đồng bộ dữ liệu mới nhất
        FE-->>BS: Hiển thị thông báo lỗi & tải lại danh sách
    end
    deactivate FE
