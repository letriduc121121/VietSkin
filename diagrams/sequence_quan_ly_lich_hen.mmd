sequenceDiagram
    actor LT as Lễ tân
    participant FE as Frontend
    participant BE as Backend
    participant DB as Database

    %% ═══════════════════════════════════════════════════════════
    %% LUỒNG CHÍNH: Xem danh sách & Check-in
    %% ═══════════════════════════════════════════════════════════

    LT->>FE: 1. Truy cập trang "Quản lý lịch hẹn"

    par Tải danh sách lịch hẹn
        FE->>BE: 2a. GET /appointments?date=today
        BE->>DB: SELECT appointments WHERE date = today
        DB-->>BE: Trả danh sách lịch hẹn
        BE-->>FE: 3a. Danh sách lịch hẹn trong ngày
    and Tải hàng chờ khám
        FE->>BE: 2b. GET /appointments?date=today (status: checked_in, in_progress)
        BE->>DB: SELECT appointments (checked_in/in_progress)
        DB-->>BE: Trả danh sách hàng chờ
        BE-->>FE: 3b. Danh sách hàng chờ khám
    end

    FE-->>LT: 4. Hiển thị danh sách lịch hẹn (bên trái)<br/>& Hàng chờ khám (bên phải)

    %% ═══════════════════════════════════════════════════════════
    %% TÙY CHỌN: Tìm kiếm / Lọc
    %% ═══════════════════════════════════════════════════════════

    opt Lễ tân tìm kiếm hoặc lọc
        LT->>FE: 5. Nhập SĐT/Tên hoặc lọc theo<br/>Ngày / Trạng thái / Bác sĩ
        FE->>BE: 6. GET /appointments?date=...&doctorId=...&status=...
        BE->>DB: SELECT appointments theo điều kiện lọc
        DB-->>BE: Trả kết quả
        BE-->>FE: 7. Danh sách đã lọc
        FE-->>LT: 8. Hiển thị kết quả tìm kiếm
    end

    %% ═══════════════════════════════════════════════════════════
    %% BƯỚC XÁC NHẬN (pending → confirmed)
    %% ═══════════════════════════════════════════════════════════

    Note over LT, DB: Bước 1: Xác nhận lịch hẹn (Trạng thái "Chờ xác nhận")

    LT->>FE: 9. Chọn lịch hẹn "Chờ xác nhận"<br/>& Nhấn nút "Xác nhận"
    FE->>BE: 10. PUT /appointments/{id}/status<br/>body: { status: "confirmed" }
    BE->>DB: UPDATE status = 'confirmed'
    DB-->>BE: OK
    BE-->>FE: 11. 200 OK - Đã xác nhận
    FE-->>LT: 12. Cập nhật trạng thái "Đã xác nhận"<br/>Nút "Check-in" xuất hiện

    %% ═══════════════════════════════════════════════════════════
    %% BƯỚC CHECK-IN (confirmed → checked_in)
    %% ═══════════════════════════════════════════════════════════

    Note over LT, DB: Bước 2: Check-in bệnh nhân (Trạng thái "Đã xác nhận")

    LT->>FE: 13. Nhấn nút "Check-in"
    FE->>BE: 14. PUT /appointments/{id}/status<br/>body: { status: "checked_in" }
    BE->>DB: UPDATE status = 'checked_in'<br/>Tính & gán Số thứ tự (queueNumber)
    DB-->>BE: OK
    BE-->>FE: 15. 200 OK (kèm WebSocket thông báo<br/>cho Lễ tân & Bác sĩ)

    par Reload danh sách
        FE->>BE: 16a. GET /appointments (reload danh sách)
        BE-->>FE: Danh sách mới nhất
    and Reload hàng chờ
        FE->>BE: 16b. GET /appointments (reload hàng chờ)
        BE-->>FE: Hàng chờ đã cập nhật
    end

    FE-->>LT: 17. Hiển thị STT & Báo "Check-in thành công"<br/>Bệnh nhân vào hàng chờ bác sĩ

    %% ═══════════════════════════════════════════════════════════
    %% LUỒNG THAY THẾ: Hủy lịch hẹn
    %% ═══════════════════════════════════════════════════════════

    alt Lễ tân hủy lịch hẹn (pending hoặc confirmed)
        LT->>FE: A1. Nhấn nút "Hủy" trên lịch hẹn
        FE-->>LT: A2. Hiển thị hộp thoại xác nhận<br/>"Hủy lịch hẹn này?"
        LT->>FE: A3. Nhấn "Đồng ý"
        FE->>BE: A4. PUT /appointments/{id}/cancel
        BE->>DB: UPDATE status = 'cancelled'
        DB-->>BE: OK
        BE-->>FE: A5. 200 OK
        FE-->>LT: A6. Cập nhật trạng thái "Đã hủy"
    end
