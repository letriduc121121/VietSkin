' ============================================================
' UC 2.3.6 - QUẢN LÝ THÔNG TIN CÁ NHÂN
' ============================================================
@startuml UC_QuanLyThongTinCaNhan
title Biểu đồ hoạt động - Quản lý thông tin cá nhân

|Người dùng|
start
:Chọn mục "Hồ sơ cá nhân";

|Hệ thống|
:Gọi API GET /users/profile;
:Hiển thị thông tin hiện tại\n(Tab: Thông tin cơ bản, Y tế, Mật khẩu);

|Người dùng|
if (Chọn tab nào?) then (Thông tin cơ bản / Y tế)
  :Chỉnh sửa thông tin cần cập nhật;
  :Nhấn "Lưu thông tin";

  |Hệ thống|
  :Gọi API PUT /users/profile;
  if (Dữ liệu hợp lệ?) then (Có)
    :Cập nhật thông tin thành công;
    :Hiển thị thông báo\n"Cập nhật thông tin thành công!";
  else (Không)
    :Hiển thị thông báo lỗi\n"Lưu thất bại";
  endif

else (Mật khẩu)

  |Người dùng|
  :Nhập mật khẩu hiện tại;
  :Nhập mật khẩu mới;
  :Nhập xác nhận mật khẩu mới;
  :Nhấn "Đổi mật khẩu";

  |Hệ thống|
  if (Mật khẩu mới trùng khớp?) then (Không)
    :Hiển thị lỗi\n"Mật khẩu xác nhận không khớp";
    stop
  else (Có)
  endif
  if (Mật khẩu >= 6 ký tự?) then (Không)
    :Hiển thị lỗi\n"Mật khẩu mới phải ít nhất 6 ký tự";
    stop
  else (Có)
  endif
  :Gọi API PUT /users/change-password;
  if (Mật khẩu cũ đúng?) then (Có)
    :Cập nhật mật khẩu mới thành công;
    :Hiển thị "Đổi mật khẩu thành công!";
  else (Không)
    :Hiển thị lỗi\n"Đổi mật khẩu thất bại";
  endif
endif
stop
@enduml


' ============================================================
' UC 2.3.7 - QUẢN LÝ DANH SÁCH LỊCH HẸN
' ============================================================
@startuml UC_QuanLyDanhSachLichHen
title Biểu đồ hoạt động - Quản lý danh sách lịch hẹn

|Lễ tân|
start
:Truy cập trang "Quản lý lịch hẹn";

|Hệ thống|
:Gọi API GET /appointments?date=hôm_nay;
:Hiển thị danh sách lịch hẹn trong ngày\nvà hàng chờ bên phải;

|Lễ tân|
if (Muốn tìm kiếm/lọc?) then (Có)
  :Nhập tên/SĐT hoặc lọc theo\nngày / trạng thái / bác sĩ;

  |Hệ thống|
  :Lọc và hiển thị kết quả;
  if (Có kết quả?) then (Không)
    :Hiển thị\n"Không tìm thấy lịch hẹn nào";
    stop
  else (Có)
  endif
else (Không)
endif

|Lễ tân|
:Xem danh sách lịch hẹn;

if (Trạng thái lịch hẹn?) then (pending)
  :Nhấn "Xác nhận";
  |Hệ thống|
  :Gọi API PUT /appointments/{id}/status\n{status: "confirmed"};
  :Cập nhật trạng thái sang "Đã xác nhận";

elseif (confirmed) then
  |Lễ tân|
  :Nhấn "Check-in";
  |Hệ thống|
  :Gọi API PUT /appointments/{id}/status\n{status: "checked_in"};
  :Tự động cấp số thứ tự trong ngày;
  :Lịch hẹn vào hàng chờ khám của bác sĩ;

else (checked_in / in_progress)
  |Hệ thống|
  :Không cho thao tác\n(nút bị ẩn);
endif
stop
@enduml


' ============================================================
' UC 2.3.8 - DUYỆT LỊCH HẸN ONLINE
' ============================================================
@startuml UC_DuyetLichHenOnline
title Biểu đồ hoạt động - Duyệt lịch hẹn online

|Lễ tân|
start
:Truy cập trang "Xác nhận lịch hẹn";

|Hệ thống|
:Gọi API GET /appointments?status=pending;
:Hiển thị danh sách lịch chờ duyệt\n(nhóm theo ngày);

if (Có lịch chờ duyệt?) then (Không)
  :Hiển thị "Không có lịch hẹn chờ duyệt\nTất cả lịch hẹn đã được xử lý";
  stop
else (Có)
endif

|Lễ tân|
:Xem chi tiết từng lịch hẹn\n(Họ tên, SĐT, Giờ khám,\nBác sĩ, Dịch vụ, Triệu chứng);

if (Chọn thao tác?) then (Xác nhận từng lịch)
  :Nhấn "Xác nhận";
  |Hệ thống|
  :Gọi API PUT /appointments/{id}/status\n{status: "confirmed"};
  :Cập nhật trạng thái "Đã xác nhận";
  :Lịch được loại khỏi danh sách chờ;

elseif (Xác nhận tất cả) then
  |Lễ tân|
  :Nhấn "Xác nhận tất cả";

  |Hệ thống|
  :Hiện hộp thoại xác nhận\n"Xác nhận tất cả N lịch hẹn?";

  |Lễ tân|
  if (Đồng ý?) then (Có)
    |Hệ thống|
    :Gọi API xác nhận cho toàn bộ danh sách;
    :Tất cả lịch chuyển sang "Đã xác nhận";
    :Danh sách chờ trống;
  else (Không)
    :Hủy thao tác;
  endif

else (Từ chối)
  |Lễ tân|
  :Nhấn "Từ chối";
  |Hệ thống|
  :Gọi API PUT /appointments/{id}/cancel;
  :Cập nhật trạng thái "Đã hủy";
  :Lịch được loại khỏi danh sách chờ;
endif
stop
@enduml


' ============================================================
' UC 2.3.9 - TẠO PHIẾU KHÁM (WALK-IN)
' ============================================================
@startuml UC_TaoPhieuKham
title Biểu đồ hoạt động - Tạo phiếu khám (Walk-in)

|Lễ tân|
start
:Nhấn "Tiếp nhận walk-in"\ntrên trang Quản lý lịch hẹn;

|Hệ thống|
:Hiển thị modal với 2 tab\n"Bệnh nhân cũ" và "Bệnh nhân mới";

|Lễ tân|
if (Chọn loại bệnh nhân?) then (Bệnh nhân cũ)
  :Nhập số điện thoại bệnh nhân;
  :Nhấn "Tìm";

  |Hệ thống|
  :Gọi API GET /appointments/lookup?phone=xxx;
  if (Tìm thấy tài khoản?) then (Có)
    :Hiển thị tên bệnh nhân;
  else (Không)
    :Hiển thị "Không tìm thấy.\nĐăng ký mới?";

    |Lễ tân|
    :Nhấn "Đăng ký mới";
    :Chuyển sang tab "Bệnh nhân mới";
    :Nhập họ tên và SĐT mới;
  endif

else (Bệnh nhân mới)
  :Nhập họ tên và SĐT mới;
endif

|Lễ tân|
:Chọn bác sĩ khám;
:Điền triệu chứng (tùy chọn);
:Nhấn "Tạo phiếu & Cấp STT";

|Hệ thống|
if (Thông tin hợp lệ?) then (Không)
  :Hiển thị lỗi tương ứng\n("Vui lòng nhập họ tên và SĐT"\nhoặc "Vui lòng chọn bác sĩ");
  stop
else (Có)
endif

if (Bệnh nhân mới?) then (Có)
  :Gọi API POST /auth/register\n{name, phone, password = SĐT};
  :Tạo tài khoản bệnh nhân tự động\n(mật khẩu mặc định = SĐT);
else (Không)
endif

:Gọi API POST /appointments\n{isWalkin: true};
:Tự động đặt trạng thái "checked_in";
:Tự động cấp số thứ tự;
:Bệnh nhân được đưa vào hàng chờ khám;
:Đóng modal, làm mới danh sách;

|Lễ tân|
:Thấy phiếu khám mới trong danh sách\nvà hàng chờ;
stop
@enduml
